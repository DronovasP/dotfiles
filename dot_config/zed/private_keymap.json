[
  {
    "bindings": {
      "ctrl-w o": "workspace::ToggleAllDocks",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "space a i": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      "space e": "pane::RevealInProjectPanel",
      "space f": "file_finder::Toggle",
      "space c": "terminal_panel::ToggleFocus",
      "space g": "git_panel::Toggle",
      "space d": "debug_panel::Toggle",
      "space a t": "agent::Toggle",
      "space s w": "pane::DeploySearch",
      "space w": "workspace::Save",
      "space t g": ["task::Spawn", { "task_name": "lazygit" }],
      "space t s": "task::Spawn",
      "space t r": "task::Rerun",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-u": "terminal::ScrollPageUp",
      "ctrl-d": "terminal::ScrollPageDown",
      "ctrl-k": "terminal::ScrollLineUp",
      "ctrl-j": "terminal::ScrollLineDown",
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown",
    },
  },
  {
    "bindings": {
      "cmd-backspace": "keymap_editor::DeleteBinding",
    },
  },
]
