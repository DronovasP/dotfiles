{
  "icon_theme": "Colored Zed Icons Theme Dark",
  "prettier": {
    "allowed": true,
  },
  "vertical_scroll_margin": 10.0,
  "sticky_scroll": {
    "enabled": false,
  },
  "languages": {
    "Zig": {
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "TypeScript": {
      "completions": {
        "words": "fallback",
      },
      "always_treat_brackets_as_autoclosed": false,
      "tab_size": 4,
      "auto_indent": "syntax_aware",
      "hard_tabs": false,
    },
  },
  "lsp_highlight_debounce": 0,
  "diagnostics_max_severity": "all",
  "completions": {
    "lsp_insert_mode": "replace_suffix",
  },
  "document_symbols": "on",
  "document_folding_ranges": "off",
  "semantic_tokens": "combined",
  "edit_predictions": {
    "mode": "eager",
    "provider": "open_ai_compatible_api",
    "open_ai_compatible_api": {
      "model": "deepseek/deepseek-v3.2",
      "api_url": "https://openrouter.ai/api/v1/chat/completions",
      "prompt_format": "deepseek_coder",
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "show_edit_predictions": false,
  "agent": {
    "thinking_display": "preview",
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "save_file": false,
          "spawn_agent": true,
          "terminal": true,
          "update_plan": true,
          "copy_path": true,
          "diagnostics": true,
          "fetch": true,
          "find_path": true,
          "grep": true,
          "list_directory": true,
          "move_path": false,
          "now": true,
          "open": true,
          "read_file": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {},
      },
      "debugger": {
        "name": "Debugger",
        "tools": {
          "save_file": false,
          "spawn_agent": true,
          "terminal": true,
          "update_plan": true,
          "copy_path": true,
          "diagnostics": true,
          "fetch": true,
          "find_path": true,
          "grep": true,
          "list_directory": true,
          "move_path": false,
          "now": true,
          "open": true,
          "read_file": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "sidebar_side": "left",
    "default_profile": "debugger",
    "dock": "left",
    "enable_feedback": false,
    "inline_assistant_model": {
      "provider": "openrouter",
      "model": "openai/gpt-5.4",
      "enable_thinking": false,
    },
    "default_model": {
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2.6",
      "enable_thinking": true,
    },
    "button": false,
    "favorite_models": [],
    "model_parameters": [],
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
    "button": false,
  },
  "outline_panel": {
    "dock": "right",
    "file_icons": true,
    "button": false,
  },
  "use_system_path_prompts": true,
  "zoomed_padding": true,
  "window_decorations": "client",
  "centered_layout": {
    "left_padding": 0.2,
  },
  "text_rendering_mode": "platform_default",
  "ui_font_family": ".ZedMono",
  "buffer_line_height": "comfortable",
  "inlay_hints": {
    "show_value_hints": true,
  },
  "show_completion_documentation": true,
  "inline_code_actions": true,
  "toolbar": {
    "breadcrumbs": false,
  },
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "OpenCode": {
      "favorite_config_option_values": {
        "model": [
          "openrouter/moonshotai/kimi-k2.6"
        ]
      },
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
      "favorite_models": [
        "openrouter/moonshotai/kimi-k2.5",
        "openrouter/minimax/minimax-m2.5",
      ],
    },
  },
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enable_preview_file_from_code_navigation": false,
    "enable_preview_from_multibuffer": false,
    "enable_preview_from_project_panel": false,
    "enabled": false,
  },
  "tabs": {
    "close_position": "right",
    "file_icons": false,
    "git_status": false,
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
    "show_pinned_tabs_in_separate_row": false,
    "show": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_branch_name": false,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
    "include_warnings": true,
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "terminal": {
    "default_height": 600,
    "button": false,
  },
  "status_bar": {
    "active_language_button": false,
    "active_encoding_button": "non_utf8",
    "cursor_position_button": false,
  },
  "project_panel": {
    "sort_mode": "directories_first",
    "auto_open": {
      "on_create": true,
    },
    "hide_root": true,
    "hide_hidden": false,
    "auto_fold_dirs": true,
    "starts_open": false,
    "auto_reveal_entries": true,
    "folder_icons": true,
    "file_icons": true,
    "git_status": true,
    "entry_spacing": "comfortable",
    "button": false,
    "dock": "right",
  },
  "vim": {
    "gdefault": true,
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "relative_line_numbers": "disabled",
  "autosave": "off",
  "vim_mode": true,
  "session": {
    "trust_all_worktrees": true,
  },
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "scrollbar": {
    "show": "never",
  },
  "theme": "Ayu Mirage",
}
